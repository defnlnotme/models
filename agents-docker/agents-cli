#!/usr/bin/env bash
set -euo pipefail

# ── agents-cli: launch the multi-agent Docker container ──────────────────────
# Runs as user 1000 inside the container. Agent settings are mounted
# to mirror the host paths.

IMAGE_NAME="${IMAGE_NAME:-agents-cli}"
CONTAINER_NAME="agents-cli-$$"
AGENTS_VOLUME="${AGENTS_VOLUME:-agents-cli-config}"

# ── Colors ───────────────────────────────────────────────────────────────────
CYAN='\033[0;36m'
GREEN='\033[0;32m'
NC='\033[0m'

CONTAINER_HOME="${CONTAINER_HOME:-/home/agent}"

log()  { echo -e "${CYAN}▸${NC} $*"; }

# ── Help ─────────────────────────────────────────────────────────────────────
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat <<EOF
agents-cli — launch the multi-agent CLI container

Usage:
  agents-cli                       Open interactive shell
  agents-cli <agent> [args...]     Run a specific agent
  agents-cli --help                Show this help

Volumes:
  agents-cli-config        → ${CONTAINER_HOME}/.config
  agents-cli-config-gemini → ${CONTAINER_HOME}/.gemini
  agents-cli-config-copilot→ ${CONTAINER_HOME}/.copilot
  agents-cli-config-qwen   → ${CONTAINER_HOME}/.qwen
  agents-cli-config-hermes → ${CONTAINER_HOME}/.hermes
  agents-cli-config-local  → ${CONTAINER_HOME}/.local

Bind-mounted paths (host → container):
  ~/dev                           → ${CONTAINER_HOME}/dev
  ~/.ssh                          → ${CONTAINER_HOME}/.ssh          (read-only)
  ~/.gitconfig                    → ${CONTAINER_HOME}/.gitconfig    (read-only)

Environment:
  IMAGE_NAME         Override image (default: agents-cli)
  CONTAINER_HOME     Container home dir (default: ${CONTAINER_HOME})
  AGENTS_VOLUME      Volume name for agent configs (default: agents-cli-config)
  (also passes through API keys from host)
EOF
    exit 0
fi

# ── Preflight ────────────────────────────────────────────────────────────────
command -v docker &>/dev/null || { echo "docker not found"; exit 1; }

if ! docker image inspect "${IMAGE_NAME}:latest" &>/dev/null; then
    log "Image ${IMAGE_NAME}:latest not found. Building..."
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    "${SCRIPT_DIR}/build.sh"
fi

# ── Initialize volumes with correct ownership ────────────────────────────────
CONTAINER_HOME="${CONTAINER_HOME:-/home/agent}"
VOLUMES=("${AGENTS_VOLUME}" "${AGENTS_VOLUME}-gemini" "${AGENTS_VOLUME}-copilot" "${AGENTS_VOLUME}-qwen" "${AGENTS_VOLUME}-hermes" "${AGENTS_VOLUME}-local")

for vol in "${VOLUMES[@]}"; do
    if ! docker volume inspect "$vol" &>/dev/null; then
        docker volume create "$vol" >/dev/null
        # Set correct ownership
        docker run --rm -v "$vol:/data" alpine chown -R 1001:1001 /data 2>/dev/null || true
    fi
done

# ── Build mount flags ────────────────────────────────────────────────────────
MOUNTS=()

mount_if_exists() {
    local src="$1" dst="$2" mode="${3:-rw}"
    [[ -e "$src" ]] && MOUNTS+=(-v "${src}:${dst}:${mode}")
}

CONTAINER_HOME="${CONTAINER_HOME:-/home/agent}"

# Agents config volume (dedicated volume for all agent configs)
MOUNTS+=(-v "${AGENTS_VOLUME}:${CONTAINER_HOME}/.config")

# Agent-specific config directories
MOUNTS+=(-v "${AGENTS_VOLUME}-gemini:${CONTAINER_HOME}/.gemini")
MOUNTS+=(-v "${AGENTS_VOLUME}-copilot:${CONTAINER_HOME}/.copilot")
MOUNTS+=(-v "${AGENTS_VOLUME}-qwen:${CONTAINER_HOME}/.qwen")
MOUNTS+=(-v "${AGENTS_VOLUME}-hermes:${CONTAINER_HOME}/.hermes")
MOUNTS+=(-v "${AGENTS_VOLUME}-local:${CONTAINER_HOME}/.local")

# Dev workspace
mount_if_exists "$HOME/dev"                     "${CONTAINER_HOME}/dev"

# Current working directory
mount_if_exists "$(pwd)"                       "/project"

# Auth (read-only)
mount_if_exists "$HOME/.ssh"                    "${CONTAINER_HOME}/.ssh"            "ro"
mount_if_exists "$HOME/.gitconfig"              "${CONTAINER_HOME}/.gitconfig"      "ro"

# ── Pass through API key env vars ────────────────────────────────────────────
DOCKER_ENV=()
pass_env() {
    local val="${!1:-}"
    [[ -n "$val" ]] && DOCKER_ENV+=(-e "$1") || true
}

pass_env OPENAI_API_KEY          || true
pass_env ANTHROPIC_API_KEY       || true
pass_env GEMINI_API_KEY          || true
pass_env GOOGLE_API_KEY          || true
pass_env GITHUB_TOKEN            || true
pass_env COPILOT_TOKEN           || true
pass_env KILO_API_KEY            || true
pass_env OPENROUTER_API_KEY      || true
pass_env HERMES_API_KEY          || true
pass_env XAI_API_KEY             || true
pass_env MISTRAL_API_KEY         || true
pass_env DEEPSEEK_API_KEY        || true
pass_env GROQ_API_KEY            || true
pass_env TOGETHER_API_KEY        || true
pass_env FIREWORKS_API_KEY       || true
pass_env AWS_ACCESS_KEY_ID       || true
pass_env AWS_SECRET_ACCESS_KEY   || true
pass_env AWS_REGION              || true
pass_env AZURE_OPENAI_API_KEY    || true
pass_env AZURE_OPENAI_ENDPOINT   || true

# ── Launch ───────────────────────────────────────────────────────────────────
log "Launching ${IMAGE_NAME}:latest"

# Build docker args as a list to handle empty arrays cleanly
DOCKER_ARGS=(--rm -it --init --name "${CONTAINER_NAME}" --network host -w /project)
DOCKER_ARGS+=(--security-opt label=disable)
DOCKER_ARGS+=("${MOUNTS[@]}")
[[ ${#DOCKER_ENV[@]} -gt 0 ]] && DOCKER_ARGS+=("${DOCKER_ENV[@]}")
DOCKER_ARGS+=("${IMAGE_NAME}:latest")
DOCKER_ARGS+=("$@")

exec docker run "${DOCKER_ARGS[@]}"
